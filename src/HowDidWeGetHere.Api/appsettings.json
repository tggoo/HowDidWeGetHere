{
  "ConnectionStrings": {
    "HistoryDb": "Host=localhost;Port=5432;Database=howdidwegethere;Username=postgres;Password=postgres"
  },
  "AdminBootstrap": {
    "Email": "",
    "Password": ""
  },
  "Database": {
    "ApplyMigrationsOnStartup": false,
    "FailStartupOnMigrationError": false,
    "MigrationRetryCount": 5,
    "MigrationRetryDelaySeconds": 5
  },
  "DataProtection": {
    "KeysPath": ""
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:5173"
    ]
  },
  "Media": {
    "StorageRootPath": "",
    "PublicBaseUrl": "",
    "MaxImageBytes": 10485760,
    "MaxAudioBytes": 52428800
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
      }
    },
    "Enrich": [
      "FromLogContext"
    ],
    "WriteTo": [
      {
        "Name": "Console"
      }
    ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
